+/// the topology/acquire-fn mismatch class (B4) unwritable by construction.
+///
+/// # Minimal resident example
+///
+/// ```rust,ignore
+/// manager.register(
+///     Registration::resident(my_resource, config)
+///         .scope(ScopeLevel::Global),
+/// )?;
+/// ```
+///
