+// ─── Public: RowHandle ───────────────────────────────────────────────────────
+
+/// Opaque handle returned by [`Manager::register`](super::Manager::register).
+///
+/// Exposes the immutable identity of the registered row (`key`, `scope`,
+/// `slot_identity`) and a `status()` snapshot. All three identity fields are
+/// pinned at registration time and cannot change.
+///
+/// The handle is `Clone` so it can be stored in multiple places. Dropping it
+/// has no side-effect on the resource lifecycle.
+///
+/// # Status query
+///
+/// `status()` accepts a `&Manager` reference (rather than holding a
+/// `Weak<Manager>` internally). This avoids a lifetime that would tie the
+/// handle to a manager borrow while remaining 'static-returnable; the manager
+/// is always available at the call site because the resource only lives while
+/// the manager lives.
+#[derive(Debug, Clone)]
+#[must_use = "a registered RowHandle exposes status; drop it only if you don't need it"]
+pub struct RowHandle {
+    /// Resource key the row was filed under.
+    key: ResourceKey,
+    /// Scope level the row was registered at.
+    scope: ScopeLevel,
+    /// Collision-free structural slot identity.
+    slot_identity: SlotIdentity,
+}
+
+impl RowHandle {
+    pub(crate) fn new(key: ResourceKey, scope: ScopeLevel, slot_identity: SlotIdentity) -> Self {
+        Self {
+            key,
+            scope,
+            slot_identity,
+        }
+    }
+
+    /// The resource key the row was filed under.
+    #[must_use]
+    pub fn key(&self) -> &ResourceKey {
+        &self.key
+    }
+
+    /// The scope level the row was registered at.
+    #[must_use]
+    pub fn scope(&self) -> &ScopeLevel {
+        &self.scope
+    }
+
+    /// The collision-free structural slot identity.
+    #[must_use]
+    pub fn slot_identity(&self) -> &SlotIdentity {
+        &self.slot_identity
+    }
+
+    /// Returns a health snapshot by looking up the row in `mgr`.
+    ///
+    /// Returns `None` when the row has been removed or the manager does not
+    /// recognise the key (e.g. after `Manager::remove`).
+    ///
+    /// The `&Manager` parameter is deliberate: it avoids storing a
+    /// `Weak<Manager>` in the handle (which would require `Arc<Manager>` at
+    /// creation time), keeps the handle 'static-returnable, and makes the
+    /// dependency explicit at the call site.
+    #[must_use]
+    pub fn status(&self, mgr: &crate::Manager) -> Option<ResourceHealthSnapshot> {
+        mgr.health_check_any(&self.key, &self.scope)
+    }
+}
