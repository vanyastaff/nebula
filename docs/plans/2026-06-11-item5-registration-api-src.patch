+/// ```rust,ignore
+/// manager.register(
+///     Registration::pooled(my_resource, config, pool_config),
+/// )?;
+/// ```
+pub struct Registration<R: Resource + HasCredentialSlots> {
+    /// Fully-constructed resource value, all credential slots resolved.
