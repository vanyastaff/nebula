# Cursor agent indexing — mirrors .claudeignore for secrets and AI runtime
# state. Doc map: docs/README.md. Keep in sync with .claudeignore: any
# secret/runtime/large-binary pattern added there must be added here too.

# ============================================================================
# RUST / BUILD ARTIFACTS
# ============================================================================

target/
**/target/
debug/
**/*.rs.bk
**/*.rs.bk.*

# Profiling
*.profraw
*.profdata
flamegraph.svg
perf.data
perf.data.old

# ============================================================================
# ENVIRONMENT & SECRETS  (must mirror .gitignore / .claudeignore)
# ============================================================================

.env
.env.*
!.env.example
.envrc
deploy/.env

# Keys / certificates (do not index — but credential source dirs are
# exempted so Cursor can still see crate sources).
*.key
*.pem
*.crt
*.p12
*.pfx
*.jks
*.keystore
*.asc
*.gpg
id_rsa
id_dsa
id_ecdsa
id_ed25519
.npmrc

secrets/
credentials/
!apps/desktop/src/features/credentials/
!crates/credential/src/credentials/
!crates/credential/src/secrets/

**/config/local.*
**/config/secrets.*

# ============================================================================
# AI TOOL RUNTIME STATE — per-user, not project-shared. Must NOT be indexed.
# ============================================================================

# Claude Code per-user state
.claude/settings.local.json
.claude/summaries/
.claude/worktrees/
.claude/agent-memory-local/
.claude/scheduled_tasks.lock

# Codex CLI: OAuth tokens, SQLite session DBs (hundreds of MB), conversation logs
.codex/

# Pi / Gentle-AI per-user runtime (project configs exempted below)
.pi/*
!.pi/settings.json
!.pi/conventions.json
!.pi/codebase-wiki.json
!.pi/wiki/
.atl/

# Compound Engineering per-project secrets / preferences
.compound-engineering/*.local.yaml

# Other AI tools — mirror .gitignore policy
.agent/
.agents/
.junie/
.qoder/
!.qoder/repowiki/
.specify/
.cursorrules
.aider*
.auto-claude/
.auto-claude-security.json
.auto-claude-status
.claude_settings.json
.code-review-graph/
.security-key
.serena/

# AI-generated scratch / ai-temp / agent root-drop files
**/ai-generated/
**/.ai-temp/
check_output.txt
build-progress.txt
context.json
implementation_plan.json
project_index.json
init.sh

# ============================================================================
# WORKTREES (large, duplicate file trees) — `.claude/worktrees/` is
# already listed under the Claude per-user-state block above.
# ============================================================================

.worktrees/

# ============================================================================
# IDE / OS NOISE
# ============================================================================

.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/
*.vsix
*.iml
*.swp
*.swo
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ============================================================================
# NODE (apps/desktop is a Tauri app)
# ============================================================================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================================
# DOCS — historical material not useful as live agent context
# ============================================================================

# Pre-0042 ADRs were evicted 2026-05-18; bodies are git-history-only.
# Live index at docs/adr/HISTORICAL.md.

# Local-only audit drops (this dir is per-snapshot, not durable)
.pi-audit-*/

# Fuzz crate lockfiles
crates/*/fuzz/Cargo.lock

# Competitor research and spike artefacts
targets/
findings/
spike-iter-1-2/
spike-iter-3/
