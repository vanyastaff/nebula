{
  "$schema": "https://unpkg.com/@aliou/pi-guardrails@0.13.2/schema.json",
  "_comment": "Nebula: guardrails отвечает за file-policies (env/target/worktrees/audit). bash-команды и external_directory отданы pi-permission-system чтобы не было двойных prompt'ов. См. CLAUDE.md § AI Context Files и § Pi Hook Strategy.",
  "enabled": true,
  "applyBuiltinDefaults": true,
  "features": {
    "pathAccess": false,
    "permissionGate": false,
    "policies": true
  },
  "policies": {
    "rules": [
      {
        "id": "secret-files",
        "description": "Files containing secrets (migrated from envFiles)",
        "protection": "noAccess",
        "allowedPatterns": [
          {
            "pattern": ".env.example",
            "regex": true
          },
          {
            "pattern": "**/.env.example",
            "regex": true
          }
        ],
        "onlyIfExists": false,
        "blockMessage": "Nebula: чтение .env заблокировано (содержит API_JWT_SECRET / API_KEYS / DATABASE_URL). Используй .env.example как шаблон.",
        "patterns": [
          {
            "pattern": ".env"
          },
          {
            "pattern": ".env.local"
          },
          {
            "pattern": ".env.production"
          },
          {
            "pattern": ".env.prod"
          },
          {
            "pattern": ".dev.vars"
          }
        ]
      }
    ]
  },
  "version": "0.9.0-20260327"
}
