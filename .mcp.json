{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ]
    },
    "serena": {
      "command": "serena",
      "args": [
        "start-mcp-server",
        "--context",
        "claude-code",
        "--project",
        "."
      ]
    },
    "cratesio": {
      "command": "cratesio-mcp"
    },
    "rust-docs": {
      "command": "rust-docs-mcp"
    },
    "rust-mcp-server": {
      "command": "rust-mcp-server",
      "args": ["--workspace", "."]
    },
    "rust-analyzer-mcp": {
      "command": "rust-analyzer-mcp"
    }
  }
}
