# Копировать в .env и подставить свои значения.
# Используется: docker compose, локальные миграции, приложение.

# Postgres (для nebula-storage, миграций, приложения)
DATABASE_URL=postgres://nebula:nebula@localhost:5432/nebula

# Опционально: Redis (если включаем feature redis у nebula-storage)
REDIS_URL=redis://localhost:6379

# API bind / exposed port for compose stacks
NEBULA_API_BIND=0.0.0.0:5678
API_PORT=5678
NEBULA_WORKER_COUNT=4

# Optional prebuilt image override for self-hosted compose
# NEBULA_API_IMAGE=ghcr.io/nebula/nebula-api:<tag>

# Service ports for docker compose mapping
POSTGRES_PORT=5432
REDIS_PORT=6379

# Postgres credentials used by compose files
POSTGRES_USER=nebula
POSTGRES_PASSWORD=nebula
POSTGRES_DB=nebula

# Logging
RUST_LOG=info
# NEBULA_LOG=info

# GitHub OAuth (desktop login)
# Create OAuth App in GitHub and set callback URL:
# http://localhost:5678/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:5678/auth/github/callback
