# Копировать в .env и подставить свои значения.
# Используется: docker compose, локальные миграции, приложение.

# Postgres (для nebula-storage, миграций, приложения)
DATABASE_URL=postgres://nebula:nebula@localhost:5432/nebula

# Опционально: Redis (если включаем feature redis у nebula-storage)
# REDIS_URL=redis://localhost:6379

# Порты и хост — при необходимости переопределить в docker-compose
# POSTGRES_PORT=5432
# REDIS_PORT=6379
