{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nebula.dev/specs/validator/validation-error-envelope.schema.json",
  "type": "object",
  "required": ["code", "message"],
  "properties": {
    "code": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "field": {
      "type": ["string", "null"]
    },
    "pointer": {
      "type": ["string", "null"]
    },
    "params": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "severity": {
      "type": "string",
      "enum": ["Error", "Warning", "Info"]
    },
    "help": {
      "type": ["string", "null"]
    },
    "nested": {
      "type": "array",
      "items": {
        "$ref": "#"
      }
    }
  },
  "additionalProperties": true
}
