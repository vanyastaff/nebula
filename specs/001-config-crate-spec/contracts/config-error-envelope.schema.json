{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nebula.dev/contracts/config/config-error-envelope.schema.json",
  "title": "ConfigErrorEnvelope",
  "description": "Stable contract for config error categories consumed by compatibility tests and downstream crates.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "category",
    "message"
  ],
  "properties": {
    "category": {
      "type": "string",
      "enum": [
        "source_load_failed",
        "merge_failed",
        "validation_failed",
        "missing_path",
        "type_mismatch",
        "invalid_value",
        "watcher_failed"
      ]
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "path": {
      "type": "string"
    },
    "source_id": {
      "type": "string"
    },
    "source_kind": {
      "type": "string"
    },
    "retryable": {
      "type": "boolean"
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    },
    "nested": {
      "type": "array",
      "items": {
        "$ref": "#"
      }
    }
  }
}
