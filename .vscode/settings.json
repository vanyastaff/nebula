{
    "//-rust-analyzer": "Use a separate target dir so RA doesn't fight cargo/agent for file locks in target/.",
    "rust-analyzer.cargo.targetDir": "target/ra",
    "rust-analyzer.check.extraEnv": {
        "CARGO_TARGET_DIR": "target/ra"
    },
    "rust-analyzer.cargo.extraEnv": {
        "CARGO_TARGET_DIR": "target/ra"
    },
    "chat.mcp.serverSampling": {
        "nebula/.vscode/mcp.json: sequential-thinking": {
            "allowedModels": [
                "copilotcli/claude-sonnet-4.6",
                "copilot/gpt-5.3-codex",
                "copilotcli/claude-opus-4.5",
                "copilot/claude-opus-4.5",
                "copilotcli/claude-opus-4.6",
                "claude-code/claude-opus-4.6",
                "copilotcli/claude-opus-4.6-fast",
                "claude-code/claude-opus-4.6-fast",
                "copilot/claude-opus-4.6-fast",
                "copilotcli/claude-sonnet-4.5",
                "claude-code/claude-sonnet-4.5",
                "copilot/claude-sonnet-4.5"
            ]
        }
    }
}