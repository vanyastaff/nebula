!.qoder/repowiki/
.specify/
.cursorrules
.aider*
.auto-claude/
.code-review-graph/

# AI-generated artifacts
**/ai-generated/
**/.ai-temp/

# Working files agents write at the repo root
check_output.txt
build-progress.txt
context.json
implementation_plan.json
project_index.json
init.sh

# Auto-claude generated state
.auto-claude-security.json
.auto-claude-status
.claude_settings.json
.security-key
logs/security/

# Git worktrees created by superpowers / manual workflows
.worktrees/

# Competitor research (transient cloned repos)
targets/

# ============================================================================
# AI FACTORY — track shared context, ignore transient per-fix / per-branch state
# ============================================================================
# Tracked (do NOT ignore): config.yaml, DESCRIPTION.md, ARCHITECTURE.md,
# RULES.md, ROADMAP.md, RESEARCH.md, SECURITY.md, rules/, references/,
# specs/, skill-context/. Plus the .ai-factory.json install manifest.

# Transient plan / fix files
.ai-factory/PLAN.md
.ai-factory/FIX_PLAN.md
.ai-factory/plans/

# Per-fix / per-branch scratch
.ai-factory/qa/
.ai-factory/patches/
.ai-factory/evolutions/
.ai-factory/evolution/

# Helper payloads written by update-config.mjs and similar tooling
.ai-factory/*.update.json

# Serena local state (mirrors .claudeignore policy)
.serena/
