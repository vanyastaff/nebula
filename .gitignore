# ============================================================================
# RUST / CARGO
# ============================================================================

# Build artifacts (covers per-worktree target/ and rust-analyzer's target/ra/)
target/
**/target/
debug/

# Cargo lockfile is committed (workspace contains binaries)
# Cargo.lock

# rustfmt backups
**/*.rs.bk
**/*.rs.bk.*

# Compiled object files
**/*.o
**/*.so
**/*.dylib
**/*.dll
**/*.a
**/*.lib

# Profiling / flamegraph
*.profraw
*.profdata
flamegraph.svg
perf.data
perf.data.old

# ============================================================================
# WINDOWS / MSVC
# ============================================================================

*.pdb
*.ilk
*.obj
*.iobj
*.ipdb
Thumbs.db
ehthumbs.db
Desktop.ini

# ============================================================================
# IDE — JetBrains (RustRover) / VSCode
# ============================================================================

# Full ignore of .idea/ (per-user IDE state, not shared)
.idea/

# VSCode: track only repo-shared settings, ignore user-local state
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/
*.vsix

# ============================================================================
# OS noise (cross-platform contributors)
# ============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

