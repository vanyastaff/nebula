# ============================================================================
# AI HARNESS RUNTIME STATE — symmetric with .codex/ above. Per-user, not
# shared. `.atl/` holds the gentle-pi skill-registry cache; `.pi/` holds
# per-project Pi settings / session state. Project-shared Pi configs
# (conventions, codebase-wiki, etc.) are exempted below so contributors
# pick up the same tooling on clone.
# ============================================================================

.atl/
.pi/*

# Committed project-shared Pi configs
!.pi/settings.json
!.pi/conventions.json
!.pi/codebase-wiki.json
!.pi/lsp.json
!.pi/wiki/
!.pi/wiki/**
!.pi/extensions/
.pi/extensions/**
!.pi/extensions/guardrails.json
!.pi/extensions/pi-permission-system/
!.pi/extensions/pi-permission-system/config.json

# Local audit drops (point-in-time snapshots, not durable docs)
.pi-audit-*/

# Agent research drops — collected articles / studies / analyses. Local-only,
# not durable docs. New drops go to the Obsidian vault raw/ (C:\Users\vanya\memory\raw\);
# this legacy in-repo raw/ stays ignored.
raw/

# project memory: junction -> Obsidian vault (C:\Users\vanya\memory\projects\nebula)
.memory/

# fastembed/ONNX model cache (obsidian-mcp semantic search side-effect — not a repo artifact)
.fastembed_cache/

# Design/planning artifacts live in the private Obsidian vault
# (C:\Users\vanya\memory\projects\nebula\{decisions,planning,specs,research}), NOT the public repo.
