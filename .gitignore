context.json
implementation_plan.json
project_index.json
init.sh

# Auto-claude generated state
.auto-claude-security.json
.auto-claude-status
.claude_settings.json
.security-key
logs/security/

# Git worktrees created by superpowers / manual workflows
.worktrees/

# Competitor research (transient cloned repos)
targets/

# Serena local state (mirrors .claudeignore policy)
.serena/

# Fuzz crate lockfiles — not redistributed and trip dep-review's
# license check on libfuzzer-sys (`(MIT OR Apache-2.0) AND NCSA`).
crates/*/fuzz/Cargo.lock

# Local audit drops (point-in-time snapshots, not durable docs)
.pi-audit-*/

# Agent research drops — collected articles / studies / analyses. Local-only,
# not durable docs. New drops go to the maintainers' private Obsidian vault
# ($OBSIDIAN_VAULT_PATH, default ~/memory); this legacy in-repo raw/ stays ignored.
raw/

# project memory: junction -> the private Obsidian vault ($OBSIDIAN_VAULT_PATH)
.memory/

# fastembed/ONNX model cache (obsidian-mcp semantic search side-effect — not a repo artifact)
.fastembed_cache/

# Design/planning artifacts live in the maintainers' private Obsidian vault
# ($OBSIDIAN_VAULT_PATH/projects/nebula/{decisions,planning,specs,research}), NOT the public repo.
# Keep the public repo clean: ADRs, roadmap, plans, brainstorms, specs, research stay out.
docs/adr/
docs/plans/
docs/brainstorms/
docs/superpowers/
docs/ROADMAP.md
docs/ARCHIVE.md
openspec/

