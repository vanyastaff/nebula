*.key
*.pem
*.crt
*.p12
*.pfx
*.jks
*.keystore
*.asc
*.gpg
id_rsa
id_dsa
id_ecdsa
id_ed25519
.npmrc
secrets/
credentials/
!apps/desktop/src/features/credentials/
!crates/credential/src/credentials/
!crates/credential/src/secrets/

**/config/local.*
**/config/secrets.*

