# Nebula — example environment file
#
# Copy this to `.env` (which is git-ignored) and fill in real values for
# local development. Any `.env.*` variant is also git-ignored except this
# `.env.example` template. Do not put secrets here.
#
# Variables below are grouped by the crate that reads them. Authoritative
# source: `apps/server/src/compose.rs`, `crates/api/src/config/` (canonical
# env-var registry in `crates/api/src/config/env.rs`), `crates/log/src/config/`,
# `crates/storage/`, `apps/server/src/transport.rs`. Only variables that
# the codebase actually consumes are listed.

# ============================================================================
# Environment metadata (apps/server, crates/api, crates/log)
# ============================================================================

# dev | staging | production. Read by compose, api/config, log, sentry.
NEBULA_ENV=dev

# Service identity used in structured logs / traces / sentry releases.
NEBULA_SERVICE=nebula
NEBULA_INSTANCE=local-dev
NEBULA_REGION=local
NEBULA_VERSION=0.0.0-dev

# ============================================================================
# Storage (crates/storage, apps/server/compose.rs)
# ============================================================================

# PostgreSQL connection string used by storage adapter and integration tests.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# DATABASE_URL=postgresql://nebula:nebula@localhost:5432/nebula

# ============================================================================
# HTTP / API (crates/api/src/config/mod.rs)
# ============================================================================

# API_BIND_ADDRESS=0.0.0.0:8080
# API_PUBLIC_URL=http://localhost:8080
# WEBHOOK_BASE_URL=http://localhost:8080

# Webhook transport (apps/server/src/transport.rs, apps/server/src/compose.rs).
# WEBHOOK_BIND_ADDRESS overrides the listener bind for webhooks;
# WEBHOOK_BOOTSTRAP_FROM_STORAGE toggles bootstrap-on-startup (default true).
# WEBHOOK_BIND_ADDRESS=0.0.0.0:8081
# WEBHOOK_BOOTSTRAP_FROM_STORAGE=true

# Comma-separated origins, or `*` for permissive dev.
# API_CORS_ORIGINS=http://localhost:5173

# Body limit in bytes (default in code).
# API_MAX_BODY_SIZE=1048576

# Request timeout in seconds.
# API_REQUEST_TIMEOUT=30

# Rate limit — plain integer, requests per second (parsed as u64 in
# `crates/api/src/config/mod.rs`). Default 100.
# API_RATE_LIMIT=100

# Header name carrying the request id (default in code).
# API_REQUEST_ID_HEADER=x-request-id

# Idempotency backend: only `memory` or `postgres` are accepted (case
# insensitive). Anything else — e.g. `redis` — fails at boot with
# ApiConfigError::ParseEnum (see crates/api/src/config/sub.rs tests).
# API_IDEMPOTENCY_BACKEND=memory

# Idempotency tuning (used by both memory and postgres backends).
# API_IDEMPOTENCY_TTL_SECS=3600
# API_IDEMPOTENCY_MAX_ENTRIES=10000
# API_IDEMPOTENCY_MAX_REQUEST_BODY_BYTES=1048576
# API_IDEMPOTENCY_MAX_RESPONSE_BODY_BYTES=1048576
# API_IDEMPOTENCY_SWEEP_INTERVAL_SECS=120

# Tracing / compression toggles.
# API_ENABLE_TRACING=true
# API_ENABLE_COMPRESSION=true

# ----------------------------------------------------------------------------
# API secrets — DO NOT commit. Generate locally; never share.
# ----------------------------------------------------------------------------

# JWT signing secret (HS256 by default). Generate with:
#   openssl rand -hex 64
# API_JWT_SECRET=replace-me

# Comma-separated API keys for the simple key auth scheme.
# API_KEYS=replace-me,another-key

# ============================================================================
# Logging (crates/log)
# ============================================================================

# tracing-style filter (e.g. `info,nebula_engine=debug`).
# RUST_LOG=info

# Nebula-specific log overrides (see crates/log/src/config/env.rs).
# NEBULA_LOG=info
# NEBULA_LOG_FORMAT=pretty       # pretty | json | compact
# NEBULA_LOG_COLORS=auto         # auto | always | never
# NEBULA_LOG_SOURCE=true         # include file:line
# NEBULA_LOG_TIME=true           # include timestamps

# ============================================================================
# Telemetry — OpenTelemetry / Sentry (crates/log)
# ============================================================================

# OTEL collector endpoint (Jaeger / Tempo / collector).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Sentry — optional. Leave SENTRY_DSN empty to disable.
# SENTRY_DSN=
# SENTRY_ENV=dev
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0.1
